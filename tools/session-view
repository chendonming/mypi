#  CLI
# ══════════════════════════════════════════════════════════════

def cmd_list(args):
    """List recent sessions."""
    sessions = find_sessions(args.project, limit=20)
    if not sessions:
        print("📭 没有找到会话文件。")
        print(f"  搜索路径: {SESSION_BASE}")
        return

    print(f"\n{'📋 Recent Pi Sessions':^60}\n")
    print(f"{'#':>3}  {'Time':<20}  {'File':<50}")
    print(f"{'─'*3}  {'─'*20}  {'─'*50}")
    for i, fp in enumerate(sessions, 1):
        mtime = datetime.fromtimestamp(fp.stat().st_mtime).strftime("%m-%d %H:%M:%S")
        name = fp.parent.name + "/" + fp.stem[:40]
        print(f"{i:>3}  {mtime:<20}  {name:<50}")
    print()


def cmd_web(args):
    """Open web viewer."""
    if args.file:
        filepath = Path(args.file).resolve()
    else:
        filepath = find_latest(args.project)

    if not filepath or not filepath.is_file():
        print(f"⚠️ 找不到会话文件。{'指定项目: ' + args.project if args.project else '使用 --list 查看可用会话'}", file=sys.stderr)
        sys.exit(1)

    print(f"📂 加载会话: {filepath}", file=sys.stderr)
    success = open_web_viewer(filepath)
    if not success:
        sys.exit(1)


def cmd_ai(args):
    """Output AI-friendly compressed session."""
    if args.file:
        filepath = Path(args.file).resolve()
    else:
        filepath = find_latest(args.project)

    if not filepath or not filepath.is_file():
        print(f"⚠️ 找不到会话文件。{'指定项目: ' + args.project if args.project else '使用 --list 查看可用会话'}", file=sys.stderr)
        sys.exit(1)

    print(compress_for_ai(filepath))


def main():
    parser = argparse.ArgumentParser(
        description="Pi Session Viewer — 人类友好（Web UI）+ AI 友好（压缩输出）",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            使用示例:
              session-view                    # 浏览器打开最新会话
              session-view --ai              # AI 压缩版输出到终端
              session-view --web -f <file>   # 浏览器打开指定会话
              session-view --list            # 列出最近会话
              session-view --ai -p my-project  # 指定项目的 AI 压缩版本
        """)
    )

    # Mode
    parser.add_argument("--web", "-w", action="store_true", help="浏览器模式（默认）")
    parser.add_argument("--ai", "-a", action="store_true", help="AI 压缩模式")
    parser.add_argument("--list", "-l", action="store_true", help="列出最近会话")

    # Options
    parser.add_argument("--file", "-f", type=str, help="指定会话 .jsonl 文件路径")
    parser.add_argument("--project", "-p", type=str, help="按项目路径筛选（如 my-pi-tools）")

    args = parser.parse_args()

    # Route
    if args.list:
        cmd_list(args)
    elif args.ai:
        cmd_ai(args)
    else:
        # Default: web mode
        cmd_web(args)


if __name__ == "__main__":
    main()
